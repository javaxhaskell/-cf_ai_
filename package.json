{
  "name": "cf_ai_clarity",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Stateful AI research & briefing agent on Cloudflare — Llama 3.3, Workflows, Vectorize, Durable Objects.",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "deploy:dry": "vite build && wrangler deploy --dry-run --outdir=.dist",
    "setup:vectorize": "node scripts/setup-vectorize.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.177",
    "@cloudflare/ai-chat": "^0.6.2",
    "agents": "^0.12.3",
    "ai": "^6.0.175",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "workers-ai-provider": "^3.1.13",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260505.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.6.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.88.0"
  },
  "engines": {
    "node": ">=20"
  }
}
